# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# JWT signing secret from Supabase dashboard → Project Settings → API → JWT Secret.
# When set, the auth middleware verifies user tokens locally with HMAC-SHA256
# (no network call). Without it, every request makes a round-trip to Supabase.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Comma-separated allowlist of email addresses that may call admin-only routes
# (POST/DELETE /api/resources, POST /api/resources/sync-youtube). Leave unset
# and ALL admin routes fail closed with 403 — which is the safe default.
ADMIN_EMAILS=devanshu.saxena@tigergraph.com

# Server Configuration
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost:3000

# Google Gemini API for AI features
GEMINI_API_KEY=your_gemini_api_key
# Model overrides (optional). Defaults are stable Gemini 2.5 GA models, picked
# for the latency/quality tradeoff each call needs:
#   QA       → gemini-2.5-pro    (deep technical answers + RAG)
#   LEARNING → gemini-2.5-flash  (snappy conversational learning flow)
#   SELECTION → gemini-2.5-flash (cheap "pick N indices" sub-call, thinking off)
# To experiment with bleeding-edge, set GEMINI_MODEL_QA=gemini-3.1-pro-preview etc.
# GEMINI_MODEL_QA=gemini-2.5-pro
# GEMINI_MODEL_LEARNING=gemini-2.5-flash
# GEMINI_MODEL_SELECTION=gemini-2.5-flash

# YouTube API for video syncing
YOUTUBE_API_KEY=your_youtube_api_key

# TigerGraph MCP Integration
# 32-byte hex key for AES-256-GCM encryption of TigerGraph credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TG_CREDENTIALS_KEY=your_32_byte_hex_key_here

# SMTP for the "Apply to Host" contact form
# For Gmail / Google Workspace: generate a 16-char app password at
# https://myaccount.google.com/apppasswords  (2-step verification must be on)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=devanshu.saxena@tigergraph.com
SMTP_PASS=your_16_char_app_password
CONTACT_TO_EMAIL=devanshu.saxena@tigergraph.com
